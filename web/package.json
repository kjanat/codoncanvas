{
  "name": "codoncanvas-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Svelte frontend for CodonCanvas, powered by the Rust/WASM engine.",
  "scripts": {
    "build:wasm": "bash scripts/build-wasm.sh",
